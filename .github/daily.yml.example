# [활성화] 이 파일을 .github/workflows/daily.yml 로 옮기면 Actions가 인식한다.
#   (gh 토큰에 workflow 스코프가 없어 초기 푸시에서 제외됨 — 웹 UI 추가 또는
#    `gh auth refresh -s workflow` 후 이동·커밋. 1차 경로는 claude.ai/code 루틴이라 선택사항.)
#
# 폴백 스케줄러 — 1차는 로컬 스케줄 루틴(에이전트 인라인 한글 요약).
# 이 워크플로는 루틴 불가 시 대체용. LLM 키가 없으므로 요약(summary_ko)은 빈 값으로
# 커밋되고(추정 금지, 헌법 III), 대시보드는 제목·출처·점수만 표시한다.
# cron은 UTC 기준 — 23:00 UTC = 익일 08:00 KST. 타이밍은 비보장(지연·skip 가능).
#
# ⚠️ 알려진 한계: dedup 원장(state/seen_urls.json)은 gitignore라 러너에 없다 →
# 이 폴백 단독 실행은 일자 간 중복 제거가 동작하지 않는다(전 항목 신규 취급).
# 장기 사용하려면 actions/cache로 state/를 보존하는 스텝을 추가할 것.
# 또한 클라우드 IP에서는 일부 소스가 차단되어 과반 미달(exit 1)로 미갱신될 수 있다 —
# 의도된 가드다(빈약 데이터로 좋은 데이터를 덮어쓰지 않음).

name: daily-trends

on:
  schedule:
    - cron: "0 23 * * *"  # 08:00 KST
  workflow_dispatch: {}     # 수동 트리거/테스트

permissions:
  contents: write           # docs/data 커밋·푸시(내장 GITHUB_TOKEN)

concurrency:
  group: daily-trends
  cancel-in-progress: false

jobs:
  collect:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Collect trends
        run: python -m scripts.collect --out docs/data

      - name: Commit & push if changed
        run: |
          git config user.name "trends-bot"
          git config user.email "trends-bot@users.noreply.github.com"
          git add docs/data
          if git diff --cached --quiet; then
            echo "변경 없음 — 커밋 건너뜀"
          else
            git commit -m "data : ($(date -u +%F)) 일일 트렌드 갱신"
            git push
          fi
